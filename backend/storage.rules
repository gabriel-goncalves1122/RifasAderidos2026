rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Todos os logados podem ver os comprovativos (para a Tesouraria poder validar)
    match /comprovantes/{allPaths=**} {
      allow read: if request.auth != null;
    }

    // NINGUÉM pode escrever, editar ou apagar ficheiros diretamente pelo Browser/App.
    // Todas as escritas são feitas pelo Backend (que usa o Admin SDK e ignora estas regras).
    match /{allPaths=**} {
      allow write: if false;
    }
  }
}
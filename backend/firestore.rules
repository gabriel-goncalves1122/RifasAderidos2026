rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Ninguém (nenhum telemóvel ou browser) pode escrever diretamente no banco de dados.
    // Todas as escritas têm de passar pela sua API segura (Express.js).
    match /{document=**} {
      allow write: if false; 
    }

    // LEITURAS (Opcionais, dependendo de como o seu Frontend lê os dados)
    
    // Se o seu Frontend lê os bilhetes usando a fetchAPI do backend, feche isto também:
    match /bilhetes/{document=**} {
      allow read: if false; 
    }

    // Se o seu Frontend ainda usa onSnapshot() ou getDocs() do SDK Web para os bilhetes:
    // match /bilhetes/{document=**} {
    //   allow read: if request.auth != null; 
    // }

    // NOTA: A coleção "usuarios" precisa de ficar aberta para leitura porque 
    // o seu Frontend na página de Secretaria usa 'getDocs(collection(db, "usuarios"))'
    match /usuarios/{documentId} {
      allow read: if request.auth != null;
    }
  }
}
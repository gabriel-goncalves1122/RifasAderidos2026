# ============================================================================
# .GITIGNORE GLOBAL ATUALIZADO (Sistema de Rifas + Microserviço OCR)
# ============================================================================

# ----------------------------------------------------------------------------
# 1. DEPENDÊNCIAS (NODE & PYTHON)
# ----------------------------------------------------------------------------
node_modules/
bower_components/

# Ambientes Virtuais Python (Cobre todas as pastas venv do projeto)
venv/
.venv/
env/
**/venv/
**/env/

# ----------------------------------------------------------------------------
# 2. VARIÁVEIS DE AMBIENTE E SEGURANÇA (SEGREDO MÁXIMO 🔒)
# ----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.local
backend/.runtimeconfig.json

# Chaves de serviço e credenciais JSON
*.json
!package.json
!tsconfig.json
!firebase.json
!.firebaserc
!manifest.json

# ----------------------------------------------------------------------------
# 3. PASTAS DE BUILD E COMPILAÇÃO
# ----------------------------------------------------------------------------
dist/
dist-ssr/
build/
frontend/dist/
frontend/build/
backend/functions/lib/

# ----------------------------------------------------------------------------
# 4. FIREBASE & EMULADORES
# ----------------------------------------------------------------------------
.firebase/
.dataconnect/
firebase-debug.log*
firestore-debug.log*
ui-debug.log*
# Banco de dados local do emulador
backend/banco-local/
**/banco-local/

# ----------------------------------------------------------------------------
# 5. MICROSERVIÇO OCR (ESPECÍFICO)
# ----------------------------------------------------------------------------
# Python Cache
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class

# Dados Bancários Sensíveis (Extratos InfinitePay)
# Nunca subir CSVs com dados reais de transações!
microservico-ocr/**/*.csv
extratos/
**/extratos/*.csv

# Ficheiros Temporários de Processamento (Imagens e PDFs baixados)
microservico-ocr/**/temp_*
*.pdf
*.jpg
*.jpeg
*.png
# Abre uma exceção apenas para imagens de assets do frontend se necessário
!frontend/src/assets/**/*

# ----------------------------------------------------------------------------
# 6. SISTEMA & IDE
# ----------------------------------------------------------------------------
.DS_Store
.vscode/*
!.vscode/extensions.json
.idea/
*.sw?

# ----------------------------------------------------------------------------
# 7. TESTES & LOGS
# ----------------------------------------------------------------------------
coverage/
frontend/coverage/
.nyc_output/
*.log
npm-debug.log*
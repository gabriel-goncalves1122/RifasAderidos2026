# ============================================================================
# .GITIGNORE GLOBAL ATUALIZADO (Sistema de Rifas + Microserviço OCR)
# ============================================================================

# ----------------------------------------------------------------------------
# 1. DEPENDÊNCIAS (NODE & PYTHON)
# ----------------------------------------------------------------------------
node_modules/
bower_components/

# Ambientes Virtuais Python
venv/
.venv/
env/
**/venv/
**/env/

# ----------------------------------------------------------------------------
# 2. VARIÁVEIS DE AMBIENTE E SEGURANÇA (SEGREDO MÁXIMO 🔒)
# ----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.local
backend/.runtimeconfig.json

# Chaves de serviço e credenciais JSON (Abordagem Segura)
# Bloqueia apenas JSONs de chaves para não destruir o package-lock e firestore.indexes
*serviceAccount*.json
*chave*.json
*credentials*.json
*secret*.json

# ----------------------------------------------------------------------------
# 3. PASTAS DE BUILD E COMPILAÇÃO
# ----------------------------------------------------------------------------
dist/
dist-ssr/
build/
frontend/dist/
frontend/build/
backend/functions/lib/

# ----------------------------------------------------------------------------
# 4. FIREBASE & EMULADORES
# ----------------------------------------------------------------------------
.firebase/
.dataconnect/
firebase-debug.log*
firestore-debug.log*
ui-debug.log*

# Banco de dados local do emulador e Backups de Exportação
backend/banco-local/
**/banco-local/
backend/firebase-export-*/
**/firebase-export-*/

# ----------------------------------------------------------------------------
# 5. MICROSERVIÇO OCR (ESPECÍFICO)
# ----------------------------------------------------------------------------
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class

# Dados Bancários Sensíveis (Extratos InfinitePay)
microservico-ocr/**/*.csv
extratos/
**/extratos/*.csv

# Ficheiros Temporários de Processamento
microservico-ocr/**/temp_*
# Ignora PDFs e imagens soltas, mas protege a pasta public e assets do frontend
*.pdf
*.jpg
*.jpeg
*.png
!frontend/src/assets/**/*
!frontend/public/**/*

# ----------------------------------------------------------------------------
# 6. SISTEMA & IDE
# ----------------------------------------------------------------------------
.DS_Store
.vscode/*
!.vscode/extensions.json
.idea/
*.sw?

# ----------------------------------------------------------------------------
# 7. TESTES & LOGS
# ----------------------------------------------------------------------------
coverage/
frontend/coverage/
.nyc_output/
*.log
npm-debug.log*